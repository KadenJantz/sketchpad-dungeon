[connection signal="delayed" from="Skeleton/Shield" to="Skeleton/Shield/Erase Effect" method="start"]
[connection signal="flung" from="Skeleton/Shield" to="Skeleton/Chest/Front Arm" method="set_rotation" binds= [0.0]]
[connection signal="at_rest" from="Movement" to="Skeleton/MovementAnimations" method="set_current_animation" binds= ["Idle"]]
[connection signal="jumped" from="Movement" to="Skeleton/MovementAnimations" method="set_current_animation" binds= ["Jump"]]
[connection signal="walked" from="Movement" to="Skeleton/MovementAnimations" method="set_current_animation" binds= ["Walk"]]
[connection signal="begin" from="Attack" to="Skeleton/ArmsAnimations" method="set_current_animation" binds= ["Warning"]]
[connection signal="begin" from="Attack" to="Attack/Stab Particle" method="set_emitting" binds= [true]]
[connection signal="begin" from="Attack" to="Attack/Stab Particle Highlights" method="set_emitting" binds= [true]]
[connection signal="end_attack" from="Attack" to="Skeleton/MovementAnimations" method="set_current_animation" binds= ["Idle"]]
[connection signal="end_attack" from="Attack" to="Attack/Stab Particle" method="set_emitting" binds= [false]]
[connection signal="end_attack" from="Attack" to="Attack/Stab Particle Highlights" method="set_emitting" binds= [false]]
[connection signal="start_attack" from="Attack" to="Skeleton/ArmsAnimations" method="set_current_animation" binds= ["Attack"]]
[connection signal="damaged" from="Health" to="Skeleton/Chest/Chestplate" method="fling_from_hit"]
[connection signal="damaged" from="Health" to="Skeleton/Head/Front Helmet" method="fling_from_hit"]
[connection signal="died" from="Health" to="Skeleton/ArmsAnimations" method="set_current_animation" binds= ["Die"]]
[connection signal="shield_lost" from="Health" to="Skeleton/Shield" method="fling_from_hit"]
